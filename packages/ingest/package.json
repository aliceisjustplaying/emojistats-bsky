{
  "name": "ingest",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./normalizer": "./src/normalizer.ts",
    "./rows": "./src/rows.ts"
  },
  "scripts": {
    "start": "bunx tsx src/index.ts",
    "dev": "bunx tsx --watch src/index.ts",
    "db:migrate": "bunx tsx src/clickhouse/migrate.ts",
    "rebuild": "bunx tsx src/clickhouse/rebuild.ts",
    "test": "bunx tsx --test src/normalizer.test.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "archive": "workspace:*",
    "@atcute/tid": "^1.0.0",
    "@clickhouse/client": "^1.10.0",
    "@skyware/jetstream": "^0.2.0",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "emoji-normalization": "workspace:*",
    "emoji-regex": "^10.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.8.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "author": "alice",
  "license": "MIT"
}
