{
  "name": "ingest",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./normalizer": "./src/normalizer.ts",
    "./rows": "./src/rows.ts"
  },
  "scripts": {
    "start": "bunx tsx src/index.ts",
    "dev": "bunx tsx --watch src/index.ts",
    "db:migrate": "bunx tsx src/clickhouse/migrate.ts",
    "rebuild": "bunx tsx src/clickhouse/rebuild.ts",
    "test": "bunx tsx --test src/normalizer.test.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "archive": "workspace:*",
    "@atcute/tid": "^1.1.2",
    "@clickhouse/client": "^1.20.0",
    "@skyware/jetstream": "^0.2.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "emoji-normalization": "workspace:*",
    "emoji-regex": "^10.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "author": "alice",
  "license": "MIT"
}
