# Postgres / Timescale connection (points at schema from schema.sql)
EMOJISTATS_DATABASE_URL=postgres://postgres:postgres@localhost:5432/emojistats
EMOJISTATS_DATABASE_SCHEMA=public

# PLC directory endpoints
BSKY_DID_PLC_URL=https://plc.directory
# Optional fallback PLC mirror
FALLBACK_PLC_URL=

# Filesystem locations
EMOJI_BACKFILL_PARQUET_DIR=./data/parquet
EMOJI_BACKFILL_CURSOR_CACHE=./pds-cursor-cache.json

# Optional filters for local dev
#EMOJI_BACKFILL_DID_ALLOWLIST=./dids.txt
#EMOJI_BACKFILL_DID_LIMIT=1000
#EMOJI_BACKFILL_CONCURRENCY=4
#EMOJI_MAX_PER_POST=250

# Metrics / Prometheus (set a unique port per consumer; use 0 to disable)
BACKFILL_METRICS_PORT=9465

# Redis queue (shared producer/consumer settings)
BACKFILL_REDIS_URL=redis://localhost:6379
BACKFILL_STREAM_NAME=emoji:repo-jobs
BACKFILL_GROUP_NAME=emoji-backfill
BACKFILL_HIGH_WATER=50000
BACKFILL_BACKPRESSURE_POLL_MS=1000

# Consumer-specific knobs (`bun run backfill`)
BACKFILL_CONSUMER_NAME=worker-local
BACKFILL_READ_COUNT=32
BACKFILL_BLOCK_MS=1000
BACKFILL_STALLED_MIN_IDLE_MS=300000
BACKFILL_STALLED_CLAIM_COUNT=128

# Producer-specific overrides (optional)
#BACKFILL_HIGH_WATER=100000
